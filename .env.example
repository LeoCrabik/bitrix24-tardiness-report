# URL приложения (ngrok URL в dev, реальный домен в prod)
APP_URL=https://your-ngrok-url.ngrok-free.app

# Битрикс24 OAuth
BITRIX_CLIENT_ID=local.xxxxxxxxxxxx
BITRIX_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis
REDIS_URL=redis://redis:6379

# Cron: время ежедневной проверки опозданий (UTC)
TARDINESS_CHECK_HOUR=10
TARDINESS_CHECK_MINUTE=0

# Порт backend
PORT=3001
